# =============================================================================
# Food Delivery Platform - Environment Variables
# =============================================================================
# Copy this file to .env and update values as needed
# Required variables must be set, optional variables have defaults
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# REQUIRED: Database name
POSTGRES_DB=food_delivery

# REQUIRED: Database password (change in production!)
POSTGRES_PASSWORD=postgres

# OPTIONAL: Database host (default: postgres for Docker, localhost for local)
POSTGRES_HOST=postgres

# OPTIONAL: Database port (default: 5432 inside containers, 5433 for host)
POSTGRES_PORT=5433

# OPTIONAL: Database user (default: postgres)
POSTGRES_USER=postgres

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# OPTIONAL: Redis host (default: redis for Docker, localhost for local)
REDIS_HOST=redis

# OPTIONAL: Redis port (default: 6379)
REDIS_PORT=6379

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# REQUIRED: JWT signing secret (CHANGE IN PRODUCTION!)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OPTIONAL: JWT expiration time (default: 24h)
# Format: number + unit (s, m, h, d) e.g., "1h", "7d", "30m"
JWT_EXPIRES_IN=24h

# =============================================================================
# SERVICE PORTS
# =============================================================================
# OPTIONAL: Service ports (defaults shown below)
# These are the host ports that map to container ports
AUTH_SERVICE_PORT=3001
RESTAURANT_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003
DELIVERY_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
ADMIN_ANALYTICS_SERVICE_PORT=3007

# OPTIONAL: Nginx gateway port (default: 80)
NGINX_PORT=80

# OPTIONAL: Elasticsearch port (default: 9200)
ELASTICSEARCH_PORT=9200

# =============================================================================
# ENVIRONMENT & LOGGING
# =============================================================================
# OPTIONAL: Node environment (default: development)
# Options: development, production, test
NODE_ENV=development

# OPTIONAL: Log level (default: info)
# Options: error, warn, info, debug, trace
LOG_LEVEL=info

# =============================================================================
# INTER-SERVICE COMMUNICATION
# =============================================================================
# OPTIONAL: Service URLs for inter-service communication
# These are used when services need to call each other
# Defaults are set to Docker service names, adjust for your setup
AUTH_SERVICE_URL=http://auth-service:3001
RESTAURANT_SERVICE_URL=http://restaurant-service:3002
ORDER_SERVICE_URL=http://order-service:3003
DELIVERY_SERVICE_URL=http://delivery-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006
ADMIN_ANALYTICS_SERVICE_URL=http://admin-analytics-service:3007

# =============================================================================
# FIRST ADMIN USER (Auto-creation)
# =============================================================================
# OPTIONAL: First admin user credentials
# These are only used if no admin users exist in the database
# The auth service will automatically create the first admin on startup
# IMPORTANT: Change these defaults in production!
FIRST_ADMIN_EMAIL=admin@foodapp.com
FIRST_ADMIN_PASSWORD=Admin123!

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
# OPTIONAL: SMTP settings for email notifications
# Leave empty to log emails to console (development mode)
# Required for production email sending

# SMTP server hostname
SMTP_HOST=

# SMTP server port (default: 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username
SMTP_USER=

# SMTP password
SMTP_PASSWORD=

# SMTP secure connection (default: false)
# Set to 'true' for port 465 (SSL), 'false' for port 587 (TLS)
SMTP_SECURE=false

# From email address (defaults to SMTP_USER if not set)
SMTP_FROM=

# =============================================================================
# ELASTICSEARCH CONFIGURATION
# =============================================================================
# OPTIONAL: Elasticsearch connection (for restaurant search)
# Default: http://localhost:9200 (or http://elasticsearch:9200 in Docker)

# Elasticsearch URL
ELASTICSEARCH_URL=http://localhost:9200

# OPTIONAL: Elasticsearch authentication (if security is enabled)
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
# OPTIONAL: File storage settings for restaurant images, menu items, etc.

# Storage type: 'local', 's3', 'gcs', or 'azure' (default: local)
STORAGE_TYPE=local

# OPTIONAL: Local storage directory (if STORAGE_TYPE=local)
UPLOAD_DIR=

# OPTIONAL: Base URL for accessing uploaded files
# Example: http://localhost:3002/uploads or https://cdn.example.com
FILE_BASE_URL=

# =============================================================================
# AWS S3 CONFIGURATION (if STORAGE_TYPE=s3)
# =============================================================================
# OPTIONAL: S3 settings for cloud storage
# Required only if STORAGE_TYPE=s3

# S3 bucket name
S3_BUCKET_NAME=

# AWS region (e.g., us-east-1, eu-west-1)
S3_REGION=

# AWS access key ID
S3_ACCESS_KEY_ID=

# AWS secret access key
S3_SECRET_ACCESS_KEY=

# OPTIONAL: S3 endpoint (for S3-compatible services like MinIO)
# Leave empty for standard AWS S3
S3_ENDPOINT=

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# OPTIONAL: GitHub Container Registry settings (for CI/CD)
# Used during deployment to pull Docker images
GITHUB_REPOSITORY_OWNER=your-username

# =============================================================================
# NOTES
# =============================================================================
# 1. Required variables will cause the application to fail if not set
# 2. Optional variables have defaults defined in the code
# 3. In production, always:
#    - Set strong JWT_SECRET (use: openssl rand -base64 32)
#    - Set strong POSTGRES_PASSWORD
#    - Configure SMTP for email sending
#    - Set NODE_ENV=production
#    - Review and secure all service URLs
# 4. For Docker Compose, service names are used for inter-service communication
# 5. Port mappings: Host ports can be changed, container ports are fixed
